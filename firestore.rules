rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isMember(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "superadmin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true
      );
    }

    // Organizations
    match /organizations/{orgId} {
      allow read: if isSignedIn() && (isMember(orgId) || isSuperAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isMember(orgId) || isSuperAdmin());
      
      // Contacts subcollection
      match /contacts/{contactId} {
        allow read, write: if isSignedIn() && (isMember(orgId) || isSuperAdmin());
      }

      // Campaigns subcollection
      match /campaigns/{campaignId} {
        allow read, write: if isSignedIn() && (isMember(orgId) || isSuperAdmin());
      }

      // Interactions subcollection
      match /interactions/{interactionId} {
        allow read, write: if isSignedIn() && (isMember(orgId) || isSuperAdmin());
      }
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // System Logs
    match /system_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }

    // System Configs
    match /system_configs/{configId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
